RUST_LOG=face_guard_backend=debug,tower_http=info

APP_HOST=0.0.0.0
APP_PORT=8080

POSTGRES_DB=face_guard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgres://postgres:postgres@postgres:5432/face_guard
DATABASE_MAX_CONNECTIONS=10

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=face-images
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123

FACE_EMBEDDING_MODEL_PATH=/app/models/buffalo_l/w600k_r50.onnx
FACE_MODEL_NAME=insightface-buffalo-l
FACE_MODEL_VERSION=w600k-r50
FACE_MODEL_DIMENSION=512
